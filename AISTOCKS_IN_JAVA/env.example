# Same variable names as the Python AI Stock Forecaster (repository root .env).
# Copy to .env in this folder and/or use the parent repo’s .env (auto-discovered).

FMP_KEYS="your_fmp_api_key_here"
POLYGON_KEYS="your_polygon_api_key_here"
ALPHAVANTAGE_KEYS="your_alphavantage_api_key_here"
SEC_CONTACT_EMAIL="your_email@example.com"

# Optional: single FMP key (used only if FMP_KEYS is unset in environment + .env overlay)
# FMP_API_KEY=

# Optional: explicit path to a .env file (file or directory containing .env)
# export AISTOCKS_DOTENV=/path/to/directory/or/.env
